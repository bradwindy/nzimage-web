# Server-side only — never prefix with NEXT_PUBLIC_, these must not reach the browser bundle.

# Base URL of the nzimageapi-lambda API Gateway (no trailing slash, no /image suffix).
IMAGE_API_URL=https://zk9rlj3um2.execute-api.ap-southeast-2.amazonaws.com

# Per-consumer secret provisioned in the lambda's ApiClientSecrets (see
# nzimageapi-lambda/docs/ACCESS-CONTROL.md). Sent as the `secret` header by
# app/api/image/route.ts; the browser never sees this value.
NZIMAGE_API_SECRET=
